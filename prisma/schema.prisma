generator client {
  provider = "prisma-client-js"
  output   = "../lib/prisma-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  SUPERVISOR
}

enum ProjectStatus {
  CREATED
  ACTIVE
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  AWAITING_REVIEW
  APPROVED
  REVISION_REQUESTED
  PAID
}

enum ProcessingStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum ReviewStatus {
  PENDING_REVIEW
  APPROVED
  REVISION_REQUESTED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  passwordHash  String?
  role          UserRole  @default(OWNER)
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  ownedProjects    Project[]         @relation("ProjectOwner")
  supervisedProjects Project[]       @relation("ProjectSupervisor")
  progressUpdates  ProgressUpdate[]
  notifications    Notification[]
  accounts         Account[]
  sessions         Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Project {
  id           String        @id @default(cuid())
  name         String
  address      String?
  status       ProjectStatus @default(CREATED)
  geofence     Json?
  ownerId      String
  supervisorId String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  owner           User             @relation("ProjectOwner", fields: [ownerId], references: [id])
  supervisor      User?            @relation("ProjectSupervisor", fields: [supervisorId], references: [id])
  milestones      Milestone[]
  benchmarks      Benchmark[]
  progressUpdates ProgressUpdate[]
  paymentRecords  PaymentRecord[]
}

model Milestone {
  id          String          @id @default(cuid())
  projectId   String
  title       String
  description String?
  dueDate     DateTime?
  status      MilestoneStatus @default(PENDING)
  order       Int             @default(0)
  budgetNgN   Int?
  invoiceUrl  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  project        Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  progressUpdates ProgressUpdate[]
  paymentRequests  PaymentRequest[]
}

model Benchmark {
  id         String   @id @default(cuid())
  projectId  String
  milestoneId String?
  title      String   @default("Benchmark")
  notes      String?
  mediaUrl   String
  mediaType  String   @default("image")
  category   String   @default("reference_photo")
  createdAt  DateTime @default(now())

  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProgressUpdate {
  id                   String           @id @default(cuid())
  projectId            String
  milestoneId          String
  supervisorId         String
  rawMediaUrls         String[]
  aiDescription        String?
  aiMarkupData         Json?
  aiCompletionEstimate Int?
  processingStatus     ProcessingStatus @default(PENDING)
  reviewStatus         ReviewStatus     @default(PENDING_REVIEW)
  supervisorNote       String?
  failureReason        String?
  retryCount           Int              @default(0)
  gpsLat               Float?
  gpsLng               Float?
  gpsManual            Boolean          @default(false)
  deviceTimestamp      DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  project    Project   @relation(fields: [projectId], references: [id])
  milestone  Milestone @relation(fields: [milestoneId], references: [id])
  supervisor User      @relation(fields: [supervisorId], references: [id])

  @@index([projectId])
  @@index([milestoneId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PaymentRequest {
  id         String   @id @default(cuid())
  milestoneId String
  amountNgN  Int
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  milestone     Milestone       @relation(fields: [milestoneId], references: [id])
  paymentRecords PaymentRecord[]

  @@index([milestoneId])
}

model PaymentRecord {
  id              String   @id @default(cuid())
  projectId       String
  paymentRequestId String?
  paidAmountNgN   Int
  receiptUrl      String
  paidAt          DateTime @default(now())
  createdAt       DateTime @default(now())

  project        Project        @relation(fields: [projectId], references: [id])
  paymentRequest PaymentRequest? @relation(fields: [paymentRequestId], references: [id])

  @@index([projectId])
}
